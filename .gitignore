# Local .terraform directory
.terraform/

# Terraform lock file (commit if desired for consistency)
# .terraform.lock.hcl

# State files
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Crash log
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!*.example.tfvars

# Backend config with credentials
backend.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
